# ==========================================
# 一攫千金くん 環境設定テンプレート
# ==========================================
# 使い方:
# 1. このファイルを .env にコピーする
# 2. COINCHECK_ACCESS_KEY / COINCHECK_SECRET_KEY を自分の値に書き換える
# 3. 通常確認中は TRADING_ENABLED=false のままにする
#
# 注意:
# .env は秘密情報を含むため、GitHubへコミットしない

# ------------------------------------------
# SQL Server 接続設定
# ------------------------------------------
# DB_DRIVER: 使用するODBCドライバー名
DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_SERVER: SQL Serverのサーバー名
DB_SERVER=MSI\SQLEXPRESS
# DB_NAME: 使用するデータベース名
DB_NAME=CryptoBot
# DB_AUTH: windows=Windows認証 / sqlserver=SQL Server認証
DB_AUTH=windows
# DB_USERNAME / DB_PASSWORD: SQL Server認証の場合のみ使用
DB_USERNAME=
DB_PASSWORD=
# DB_TRUST_SERVER_CERTIFICATE: 証明書を信頼するか
DB_TRUST_SERVER_CERTIFICATE=yes
# DB_ENCRYPT: SQL Server接続を暗号化するか
DB_ENCRYPT=yes

# ------------------------------------------
# Coincheck API 設定
# ------------------------------------------
# COINCHECK_BASE_URL: Coincheck APIのベースURL
COINCHECK_BASE_URL=https://coincheck.com
# COINCHECK_ACCESS_KEY: Coincheckで取得したアクセスキー
COINCHECK_ACCESS_KEY=
# COINCHECK_SECRET_KEY: Coincheckで取得したシークレットキー
COINCHECK_SECRET_KEY=

# ------------------------------------------
# LINE通知設定
# ------------------------------------------
# LINE_CHANNEL_ACCESS_TOKEN: LINE Messaging APIのチャネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=
# LINE_USER_ID: 通知先ユーザーID
LINE_USER_ID=

# ------------------------------------------
# 基本設定
# ------------------------------------------
# EXCHANGE_NAME: 取引所名
EXCHANGE_NAME=coincheck
# SYMBOL: 取引対象ペア
SYMBOL=BTC_JPY
# BASE_SYMBOL: 取引対象の暗号資産
BASE_SYMBOL=BTC
# QUOTE_SYMBOL: 建値通貨
QUOTE_SYMBOL=JPY

# ------------------------------------------
# 実売買・戦略設定
# ------------------------------------------
# TRADING_ENABLED: trueにするとOrderServiceから実注文を送る。通常確認中はfalse
TRADING_ENABLED=false
# ORDER_AMOUNT_JPY: 実注文時の注文金額
ORDER_AMOUNT_JPY=5000
# LIVE_TEST_ORDER_AMOUNT_JPY: GUIの少額実注文テストで使う注文金額。推奨は500円
LIVE_TEST_ORDER_AMOUNT_JPY=500
# MIN_ORDER_AMOUNT_JPY: これ未満の成行買い注文は送信しない
MIN_ORDER_AMOUNT_JPY=500
# ORDER_COOLDOWN_SECONDS: 同じ種類の注文を連続送信しないための待ち時間
ORDER_COOLDOWN_SECONDS=300
# TAKE_PROFIT_RATE: 利確率。0.005 = +0.5%
TAKE_PROFIT_RATE=0.005
# STOP_LOSS_RATE: 損切り率。0.007 = -0.7%
STOP_LOSS_RATE=0.007
# MAIN_LOOP_INTERVAL_SECONDS: main.py定期実行の間隔秒
MAIN_LOOP_INTERVAL_SECONDS=60
# STRATEGY_NAME: 使用する戦略名
# sma_rsi_trend  = SMA上向き + RSI<70
# sma_cross_only = SMA上向きのみ
# rsi_oversold   = RSI<=30の逆張り
STRATEGY_NAME=sma_rsi_trend

# ------------------------------------------
# バックテスト設定
# ------------------------------------------
# BACKTEST_INITIAL_JPY: バックテスト開始時の仮想資金
BACKTEST_INITIAL_JPY=100000
# BACKTEST_ORDER_AMOUNT_JPY: バックテスト1回あたりの仮想注文金額
BACKTEST_ORDER_AMOUNT_JPY=5000

# ------------------------------------------
# リスク管理設定
# ------------------------------------------
# MAX_DAILY_LOSS_RATE: 日次最大損失率。0.03 = -3%
MAX_DAILY_LOSS_RATE=0.03
# MAX_DAILY_LOSS_JPY: 1日の実現損益がこの金額を超えてマイナスなら自動売買を止める
MAX_DAILY_LOSS_JPY=3000
# MAX_CONSECUTIVE_LOSSES: 最大連続損切り回数
MAX_CONSECUTIVE_LOSSES=3
# API_RETRY_COUNT: API失敗時のリトライ回数
API_RETRY_COUNT=3
# API_RETRY_INTERVAL_SECONDS: APIリトライ間隔秒
API_RETRY_INTERVAL_SECONDS=5
